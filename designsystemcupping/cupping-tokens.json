{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "CUPPING Design Tokens v1.0 — The Sensory Lab",
  "primitive": {
    "color": {
      "cream":            { "$type": "color", "$value": "#F5EDE0" },
      "parchment":        { "$type": "color", "$value": "#DDD0BD" },
      "linen":            { "$type": "color", "$value": "#EDE4D4" },
      "espresso":         { "$type": "color", "$value": "#2A1F17" },
      "espresso-light":   { "$type": "color", "$value": "#4A3B2E" },
      "white":            { "$type": "color", "$value": "#FFFFFF" },
      "copper": {
        "50":  { "$type": "color", "$value": "#FAF0E6" },
        "100": { "$type": "color", "$value": "#EDD8C0" },
        "200": { "$type": "color", "$value": "#D4B896" },
        "300": { "$type": "color", "$value": "#C9A57A" },
        "400": { "$type": "color", "$value": "#B8895A" },
        "500": { "$type": "color", "$value": "#A8693A" },
        "600": { "$type": "color", "$value": "#8B5232" },
        "700": { "$type": "color", "$value": "#7A4A25" },
        "800": { "$type": "color", "$value": "#5C3518" },
        "900": { "$type": "color", "$value": "#3D220E" }
      },
      "roast": {
        "light":       { "$type": "color", "$value": "#D4A645" },
        "medium":      { "$type": "color", "$value": "#9A6B3A" },
        "medium-dark": { "$type": "color", "$value": "#6B4530" },
        "dark":        { "$type": "color", "$value": "#3E2820" }
      },
      "flavor": {
        "chocolate": { "$type": "color", "$value": "#7B5B3A" },
        "nutty":     { "$type": "color", "$value": "#9A7D5E" },
        "fruity":    { "$type": "color", "$value": "#C8574E" },
        "floral":    { "$type": "color", "$value": "#B87A96" },
        "citrus":    { "$type": "color", "$value": "#D4A030" },
        "spicy":     { "$type": "color", "$value": "#B85430" },
        "herbal":    { "$type": "color", "$value": "#5A9A6A" },
        "sweet":     { "$type": "color", "$value": "#C9A57A" },
        "earthy":    { "$type": "color", "$value": "#6B5B4A" },
        "smoky":     { "$type": "color", "$value": "#5A5048" }
      },
      "semantic": {
        "success": { "$type": "color", "$value": "#5A9A6A" },
        "warning": { "$type": "color", "$value": "#D4A030" },
        "error":   { "$type": "color", "$value": "#C44030" },
        "info":    { "$type": "color", "$value": "#4A7AB0" }
      }
    },
    "spacing": {
      "xs":  { "$type": "dimension", "$value": "4px" },
      "sm":  { "$type": "dimension", "$value": "8px" },
      "md":  { "$type": "dimension", "$value": "12px" },
      "lg":  { "$type": "dimension", "$value": "16px" },
      "xl":  { "$type": "dimension", "$value": "24px" },
      "2xl": { "$type": "dimension", "$value": "32px" },
      "3xl": { "$type": "dimension", "$value": "48px" },
      "4xl": { "$type": "dimension", "$value": "64px" }
    },
    "radius": {
      "sm":   { "$type": "dimension", "$value": "4px" },
      "md":   { "$type": "dimension", "$value": "8px" },
      "lg":   { "$type": "dimension", "$value": "12px" },
      "xl":   { "$type": "dimension", "$value": "16px" },
      "full": { "$type": "dimension", "$value": "9999px" }
    },
    "font-family": {
      "display": { "$type": "fontFamily", "$value": ["Instrument Serif", "Georgia", "serif"] },
      "body":    { "$type": "fontFamily", "$value": ["Outfit", "system-ui", "sans-serif"] },
      "mono":    { "$type": "fontFamily", "$value": ["JetBrains Mono", "ui-monospace", "monospace"] }
    }
  },
  "semantic": {
    "color": {
      "bg": {
        "primary":   { "$type": "color", "$value": "{primitive.color.white}", "$description": "Main background" },
        "secondary": { "$type": "color", "$value": "{primitive.color.cream}", "$description": "Secondary surfaces" },
        "card":      { "$type": "color", "$value": "{primitive.color.white}", "$description": "Card background" },
        "accent":    { "$type": "color", "$value": "{primitive.color.copper.50}", "$description": "Accent background" }
      },
      "text": {
        "primary":   { "$type": "color", "$value": "{primitive.color.espresso}" },
        "secondary": { "$type": "color", "$value": "{primitive.color.espresso-light}" },
        "tertiary":  { "$type": "color", "$value": "#9A8B7A" },
        "inverse":   { "$type": "color", "$value": "{primitive.color.cream}" },
        "accent":    { "$type": "color", "$value": "{primitive.color.copper.500}" }
      },
      "border": {
        "default":  { "$type": "color", "$value": "{primitive.color.parchment}" },
        "subtle":   { "$type": "color", "$value": "{primitive.color.linen}" },
        "emphasis": { "$type": "color", "$value": "{primitive.color.copper.200}" }
      },
      "accent": {
        "primary": { "$type": "color", "$value": "{primitive.color.copper.500}" },
        "hover":   { "$type": "color", "$value": "{primitive.color.copper.600}" },
        "active":  { "$type": "color", "$value": "{primitive.color.copper.700}" }
      },
      "rating": {
        "filled": { "$type": "color", "$value": "{primitive.color.copper.600}" },
        "empty":  { "$type": "color", "$value": "#E0D5C6" },
        "hover":  { "$type": "color", "$value": "{primitive.color.copper.500}" }
      }
    }
  },
  "component": {
    "button": {
      "primary": {
        "bg":       { "$type": "color", "$value": "{semantic.color.accent.primary}" },
        "bg-hover": { "$type": "color", "$value": "{semantic.color.accent.hover}" },
        "text":     { "$type": "color", "$value": "{primitive.color.white}" },
        "radius":   { "$type": "dimension", "$value": "{primitive.radius.md}" }
      },
      "secondary": {
        "bg":       { "$type": "color", "$value": "transparent" },
        "bg-hover": { "$type": "color", "$value": "{primitive.color.copper.50}" },
        "text":     { "$type": "color", "$value": "{primitive.color.copper.500}" },
        "border":   { "$type": "color", "$value": "{primitive.color.copper.200}" }
      }
    },
    "card": {
      "bg":      { "$type": "color", "$value": "{semantic.color.bg.card}" },
      "border":  { "$type": "color", "$value": "{semantic.color.border.default}" },
      "radius":  { "$type": "dimension", "$value": "{primitive.radius.lg}" },
      "padding": { "$type": "dimension", "$value": "{primitive.spacing.lg}" }
    },
    "flavor-tag": {
      "radius":    { "$type": "dimension", "$value": "{primitive.radius.full}" },
      "padding-x": { "$type": "dimension", "$value": "{primitive.spacing.md}" },
      "padding-y": { "$type": "dimension", "$value": "{primitive.spacing.xs}" }
    },
    "input": {
      "bg":           { "$type": "color", "$value": "{primitive.color.white}" },
      "border":       { "$type": "color", "$value": "{semantic.color.border.default}" },
      "border-focus": { "$type": "color", "$value": "{primitive.color.copper.300}" },
      "radius":       { "$type": "dimension", "$value": "{primitive.radius.md}" }
    }
  }
}
